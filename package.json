{
  "name": "@kne/fastify-task",
  "version": "3.0.0-alpha.9",
  "description": "一个 Fastify 插件，用于任务编排、追踪任务执行状态和结果。支持系统自动执行和手动执行两种模式，提供完整的任务生命周期管理",
  "main": "index.js",
  "scripts": {
    "init": "husky",
    "dev": "nodemon ./index.js",
    "start": "node ./index.js",
    "build:md": "npx @kne/md-doc",
    "start:md": "npx @kne/md-doc --watch",
    "prettier": "prettier --config .prettierrc --write '{libs/**/*,index}.{js,jsx,ts,tsx,json,css,scss}'",
    "lint-staged": "npx lint-staged",
    "test": "mocha test/**/*.test.js",
    "test:coverage": "nyc --reporter=html --reporter=text mocha test/**/*.test.js"
  },
  "lint-staged": {
    "{libs/**/*,index}.{js,jsx,ts,tsx,json,css,scss}": [
      "prettier --config .prettierrc --write",
      "git add"
    ]
  },
  "files": [
    "index.js",
    "libs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kne-union/fastify-task.git"
  },
  "keywords": [],
  "author": "linzp",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kne-union/fastify-task/issues"
  },
  "homepage": "https://github.com/kne-union/fastify-task#readme",
  "peerDependencies": {
    "@kne/fastify-namespace": "*",
    "@kne/fastify-sequelize": "*",
    "fastify-plugin": ">=5"
  },
  "devDependencies": {
    "@fastify/env": "^5.0.2",
    "@kne/fastify-namespace": "*",
    "@kne/fastify-sequelize": "^3.0.6",
    "chai": "^6.2.2",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "husky": "^9.0.11",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.3",
    "nyc": "^17.1.0",
    "prettier": "^3.2.5",
    "sinon": "^21.0.0",
    "sqlite3": "^5.1.7"
  },
  "dependencies": {
    "@kne/fastify-statistics": "^0.1.1",
    "dayjs": "^1.11.20",
    "fastify-cron": "^1.4.0",
    "fs-extra": "^11.3.0"
  }
}
